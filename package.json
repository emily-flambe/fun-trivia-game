{
  "name": "fun-trivia-game",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "dev:client": "vite --config vite.config.app.ts",
    "build": "vite build --config vite.config.app.ts",
    "deploy": "vite build --config vite.config.app.ts && wrangler deploy",
    "test": "vitest run -c vitest.unit.config.ts",
    "test:worker": "vitest run -c vitest.config.mts",
    "test:all": "vitest run -c vitest.unit.config.ts && vitest run -c vitest.config.mts",
    "test:e2e": "npm run build && npx playwright test",
    "seed": "node scripts/seed.mjs"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.1",
    "@cloudflare/workers-types": "^4.20260404.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wrangler": "^4.78.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.9.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  }
}
