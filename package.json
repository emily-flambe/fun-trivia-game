{
  "name": "fun-trivia-game",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "dev:client": "vite --config vite.config.app.ts",
    "build": "vite build --config vite.config.app.ts",
    "deploy": "vite build --config vite.config.app.ts && wrangler deploy",
    "test": "vitest run -c vitest.unit.config.ts",
    "test:worker": "vitest run -c vitest.config.ts",
    "test:all": "vitest run -c vitest.unit.config.ts && vitest run -c vitest.config.ts",
    "test:e2e": "npm run build && npx playwright test",
    "seed": "node scripts/seed.mjs"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20241230.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.0",
    "vite": "^8.0.3",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "agents": "^0.8.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.25.76"
  }
}
